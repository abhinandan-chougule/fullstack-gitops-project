@Library('Shared') _
pipeline {
    agent { label 'Node' }

    parameters {
        string(name: 'FRONTEND_DOCKER_TAG', defaultValue: 'frontend', description: 'Frontend Docker tag')
        string(name: 'BACKEND_DOCKER_TAG', defaultValue: 'backend', description: 'Backend Docker tag')
    }

    environment {
        REPO_URL = "https://github.com/abhinandan-chougule/fullstack-gitops-project.git"
        BRANCH   = "main"
    }

    stages {
        stage("Workspace cleanup") {
            steps {
                cleanWs()
            }
        }

        stage("Git: Code Checkout") {
            steps {
                script {
                    code_checkout(env.REPO_URL, env.BRANCH)
                }
            }
        }

        stage("Verify: Docker Image Tags") {
            steps {
                echo "FRONTEND_DOCKER_TAG: ${params.FRONTEND_DOCKER_TAG}"
                echo "BACKEND_DOCKER_TAG: ${params.BACKEND_DOCKER_TAG}"
            }
        }

        stage("Update: Kubernetes manifests") {
            steps {
                dir('kubernetes') {
                    sh """
                        sed -i 's|fullstack-backend-beta:.*|fullstack-backend-beta:${params.BACKEND_DOCKER_TAG}|g' backend.yaml
                        sed -i 's|fullstack-frontend-beta:.*|fullstack-frontend-beta:${params.FRONTEND_DOCKER_TAG}|g' frontend.yaml
                    """
                }
            }
        }

        stage("Git: Code update and push to GitHub") {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'Github-cred',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )
                ]) {
                    sh '''
                        set -e
                        git config user.name "Jenkins"
                        git config user.email "jenkins@ci.com"
                        git add kubernetes/*.yaml
                        git diff --cached --quiet || git commit -m "Updated image tags: frontend=${FRONTEND_DOCKER_TAG} backend=${BACKEND_DOCKER_TAG}"
                        git remote set-url origin https://$GIT_USER:$GIT_TOKEN@github.com/abhinandan-chougule/fullstack-gitops-project.git
                        git push origin main
                    '''
                }
            }
        }
    }

    post {
        always {
            script {
                def recipient = "hardchougule@gmail.com"
                echo ">>> Attempting to send simple test email to: ${recipient}"
                emailext(
                    subject: "Pipeline test email - ${currentBuild.result}",
                    to: recipient,
                    body: "Pipeline finished with result: ${currentBuild.result}\nProject: ${env.JOB_NAME}\nBuild Number: ${env.BUILD_NUMBER}\nURL: ${env.BUILD_URL}"
                )
                echo ">>> Email notification step executed."
            }
        }
    }
}
