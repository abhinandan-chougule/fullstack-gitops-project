@Library('Shared') _
pipeline {
    agent { label 'Node' }

    parameters {
        string(name: 'FRONTEND_DOCKER_TAG', defaultValue: '', description: 'Frontend image tag')
        string(name: 'BACKEND_DOCKER_TAG', defaultValue: '', description: 'Backend image tag')
    }

    stages {
        stage("Validate Parameters") {
            steps {
                script {
                    if (params.FRONTEND_DOCKER_TAG == '' || params.BACKEND_DOCKER_TAG == '') {
                        error("FRONTEND_DOCKER_TAG and BACKEND_DOCKER_TAG must be provided.")
                    }
                }
            }
        }

        stage("Workspace Cleanup") {
            steps {
                cleanWs()
            }
        }

        stage("Git: Code Checkout") {
            steps {
                script {
                    code_checkout(
                        "https://github.com/abhinandan-chougule/fullstack-gitops-project.git",
                        "main"
                    )
                }
            }
        }

        stage("Update Kubernetes Manifests") {
            steps {
                dir("Automations") {
                    sh "bash updatebackendnew.sh"
                    sh "bash updatefrontendnew.sh"
                }
            }
        }

        stage("Git: Push Changes & Raise PR") {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github',
                    usernameVariable: 'GITHUB_USER',
                    passwordVariable: 'GITHUB_TOKEN'
                )]) {
                    sh """
                        git config --global user.email "jenkins@ci.com"
                        git config --global user.name "Jenkins"

                        echo ${GITHUB_TOKEN} | gh auth login --with-token

                        BRANCH_NAME="update-image-tags-\$(date +%Y%m%d%H%M%S)"

                        git checkout main
                        git pull origin main
                        git checkout -b \$BRANCH_NAME

                        git add kubernetes/backend.yaml kubernetes/frontend.yaml
                        git commit -m "Update image tags: frontend=${params.FRONTEND_DOCKER_TAG} backend=${params.BACKEND_DOCKER_TAG}"

                        git push https://${GITHUB_USER}:${GITHUB_TOKEN}@github.com/abhinandan-chougule/fullstack-gitops-project.git \$BRANCH_NAME

                        gh pr create \
                            --title "Update image tags: ${params.FRONTEND_DOCKER_TAG}" \
                            --body "## Changes
                            - Frontend image tag: ${params.FRONTEND_DOCKER_TAG}
                            - Backend image tag: ${params.BACKEND_DOCKER_TAG}
                            - Updated by Jenkins CD Pipeline
                            - Build URL: ${env.BUILD_URL}" \
                            --base main \
                            --head \$BRANCH_NAME \
                            --repo abhinandan-chougule/fullstack-gitops-project
                    """
                }
            }
        }
    }

    post {
        success {
            echo "PR raised successfully. Waiting for approval before ArgoCD syncs."
        }
        failure {
            echo "Pipeline failed. Please check the logs."
        }
    }
}
```

---

## How It Works End to End
```
CD Pipeline triggers
        ↓
Update kubernetes/backend.yaml & frontend.yaml
        ↓
Create branch: update-image-tags-20240226120000
        ↓
Commit changes
        ↓
Push branch to GitHub
        ↓
Raise PR → main
        ↓
Team reviews & approves PR
        ↓
Merge to main
        ↓
ArgoCD detects change in main
        ↓
Auto sync to Kubernetes cluster
